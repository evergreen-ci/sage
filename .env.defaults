PORT=8080

# Evergreen
EVERGREEN_API_USER=sage
EVERGREEN_API_KEY=mysecret
USER_NAME=regular

# Kanopy JWT verification
# Set to the JWKS endpoint of the Kanopy OIDC provider in production/staging.
# If unset in a production-like environment, requests will be rejected.
# Leave empty for local development (JWT signature is not verified, USER_NAME is used instead).
KANOPY_JWKS_URI=

# DB
DB_NAME=sage


# Logging
LOG_LEVEL=info

# Secrets
AZURE_OPENAI_API_KEY=your_azure_open_api_key
AZURE_OPENAI_ENDPOINT=azure_open_ai_endpoint
OTEL_COLLECTOR_URL=
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_ENDPOINT=your_anthropic_endpoint

# JIRA Config
JIRA_API_TOKEN=your_jira_token
JIRA_BASE_URL="https://jira.mongodb.org"

SENTRY_ENABLED=false

# Encryption
# ENCRYPTION_KEY: 32-byte hex string (64 characters) for AES-256 encryption
# Generate with: openssl rand -hex 32
# The default value below is for local development only - DO NOT use in production
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Sentry Error Tracking
# Set SENTRY_ENABLED=true and provide a DSN to enable error tracking
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_DEBUG=false
SENTRY_ATTACH_STACKTRACE=true
SENTRY_CAPTURE_CONSOLE=false
